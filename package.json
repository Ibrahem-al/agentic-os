{
  "name": "agentic-os",
  "version": "0.1.13",
  "description": "Agentic OS — local-first memory-and-tool backend for AI agents (Electron, embedded RyuGraph).",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "seed:demo": "esbuild tests/fixtures/dashboard-seed.ts --bundle --platform=node --format=esm --outfile=out/smoke/dashboard-seed.mjs --log-level=warning && node out/smoke/dashboard-seed.mjs",
    "rebuild:native": "node scripts/native/rebuild-native.cjs",
    "icons": "node scripts/build/generate-icons.mjs",
    "package": "electron-builder --publish never",
    "package:dir": "electron-builder --dir --publish never",
    "smoke:boot": "node scripts/smoke/boot-smoke.mjs",
    "smoke:packaged": "node scripts/smoke/packaged-smoke.mjs"
  },
  "dependencies": {
    "@huggingface/tokenizers": "0.1.3",
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "1.4.7",
    "@langchain/langgraph-checkpoint": "1.1.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-async-hooks": "2.9.0",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "croner": "10.0.1",
    "electron-updater": "6.8.9",
    "ignore": "7.0.5",
    "onnxruntime-node": "1.27.0",
    "ryugraph": "25.9.1",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.26.10",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "4.1.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.62.1",
    "vite": "7.3.6",
    "vitest": "4.1.9"
  },
  "author": "Ibrahem Alkurdi <ibrahem.alkurdi@gwmail.gwu.edu>"
}
