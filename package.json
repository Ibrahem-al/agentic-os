{
  "name": "agentic-os",
  "version": "0.0.1",
  "description": "Agentic OS — local-first memory-and-tool backend for AI agents (Electron, embedded RyuGraph).",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
