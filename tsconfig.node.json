{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/integration/**/*.ts",
    "tests/e2e/**/*.ts",
    "tests/fixtures/**/*.ts",
    "playwright.config.ts",
    // DOM-free renderer libs unit-tested from tests/unit (pure functions over
    // shared DTOs) — listed so the composite project can typecheck their test
    // imports (TS6307). NOT a general renderer include: files here avoid DOM/React.
    "src/renderer/src/lib/plain.ts",
    "src/renderer/src/lib/stagedSummary.ts",
    "src/renderer/src/lib/nodeSummary.ts"
  ],
  "exclude": [
    "tests/fixtures/mini-repo",
    "tests/fixtures/sandbox-probes"
  ]
}
