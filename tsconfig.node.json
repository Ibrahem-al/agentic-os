{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/integration/**/*.ts",
    "tests/fixtures/**/*.ts"
  ],
  "exclude": [
    "tests/fixtures/mini-repo",
    "tests/fixtures/sandbox-probes"
  ]
}
